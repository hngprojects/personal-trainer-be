APP_ENV=development
PORT=8080
LOG_LEVEL=info

# Optional log format override.
#   pretty -> human-friendly text + colors (default in development)
#   json   -> single-line JSON (default in non-development envs)
# LOG_FORMAT=

# Postgres connection string used by both the app and the migrate CLI.
# Example: postgres://user:pass@localhost:5432/go_starter?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_starter?sslmode=disable
